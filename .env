BASE_URL=https://books.toscrape.com
LISTING_PATH=/catalogue/page-1.html
ITEM_SELECTOR=article.product_pod
TITLE_SELECTOR=h3 a
LINK_SELECTOR=h3 a
PRICE_SELECTOR=.price_color 
DETAIL_LOCATION_SELECTOR=.breadcrumb li:nth-child(3)
DETAIL_DESCRIPTION_SELECTOR=#product_description + p
MAX_PAGES=2
EUR_TO_INR_RATE=109.86

OUTPUT_DIR=output
LOGS_DIR=logs
HEADLESS=true